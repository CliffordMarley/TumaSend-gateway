# =====================================================================
# TUMA PLATFORM — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# =====================================================================

# ── Server ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── Firebase Admin SDK ────────────────────────────────────────────────
# Option A — path to service account JSON file:
FIREBASE_SERVICE_ACCOUNT=./src/config/serviceAccountKey.json
# Option B — inline JSON string (useful for Docker / CI secrets):
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Kannel (SMSC gateway) ─────────────────────────────────────────────
KANNEL_HOST=127.0.0.1
KANNEL_PORT=13013
KANNEL_SENDSMS_URL=http://127.0.0.1:13013/cgi-bin/sendsms
KANNEL_USERNAME=your-kannel-username
KANNEL_PASSWORD=your-kannel-password

# ── PayChangu ─────────────────────────────────────────────────────────
PAYCHANGU_API_KEY=sec-live-your-secret-key
PAYCHANGU_SECRET_KEY=sec-live-your-secret-key
PAYCHANGU_PUBLIC_KEY=pub-live-your-public-key
# Webhook HMAC secret — set in the PayChangu dashboard
PAYCHANGU_WEBHOOK_SECRET=your-webhook-secret

# ── Application URLs ──────────────────────────────────────────────────
# Public-facing backend URL (used in Kannel DLR callback + PayChangu callbacks)
API_BASE_URL=https://api.your-domain.com
# Frontend URL (used in PayChangu return/cancel redirect)
FRONTEND_URL=https://your-domain.com
# ── Airtel Malawi HTTP SMS ────────────────────────────────────────────────────
# Airtel numbers (2659xx) are automatically routed to this HTTP gateway.
# TNM and all other numbers are routed via Kannel.
AIRTEL_SMS_BASE_URL=https://www.airtel.mw/gateway/v1
# Note: iqsms.airtel.in is the India endpoint and is unreachable from Malawi servers
AIRTEL_SMS_CLIENT_ID=your-client-uuid
AIRTEL_SMS_USERNAME=your-username
AIRTEL_SMS_PASSWORD=your-password
# ── Security ──────────────────────────────────────────────────────────
# System API key — all internal/dashboard requests send this as x-system-key
SYSTEM_API_KEY=generate-a-random-32-char-secret-here
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
